# VDE Cockpit — variables d'environnement (modèle).
# Copier vers .env.local (gitignoré) et renseigner. NE JAMAIS committer .env.local.

# Supabase (fournis par Oury). Sans ces clés, l'app tourne en mode démo local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Uniquement pour le script d'import AppSheet (scripts/import-appsheet.ts --commit).
# Clé service_role : contourne la RLS. NE JAMAIS exposer côté navigateur.
SUPABASE_SERVICE_ROLE_KEY=
