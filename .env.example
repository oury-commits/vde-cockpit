# VDE Cockpit — variables d'environnement (modèle).
# Copier vers .env.local (gitignoré) et renseigner. NE JAMAIS committer .env.local.

# Supabase (fournis par Oury). Sans ces clés, l'app tourne en mode démo local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Uniquement pour le script d'import AppSheet (scripts/import-appsheet.ts --commit).
# Clé service_role : contourne la RLS. NE JAMAIS exposer côté navigateur.
SUPABASE_SERVICE_ROLE_KEY=

# Mode ouvert (dev) : true = garde d'auth désactivée, /leads accessible sans
# login. DOIT rester false hors développement local (voir « AVANT MISE EN
# LIGNE » dans le README). Nécessite aussi les policies de
# supabase/dev-only/0002_dev_open_access.sql — volontairement HORS de
# migrations/ pour qu'aucun outil ne les applique automatiquement.
NEXT_PUBLIC_AUTH_DISABLED=false

# Envoi des devis/factures au client (Resend). Clé SERVEUR uniquement :
# lue par app/api/send-devis, jamais exposée au navigateur. Sans elle, l'app
# bascule sur le fallback mailto: (PDF téléchargé, à joindre à la main).
RESEND_API_KEY=

# ── Planning / Google Calendar (Bloc A) — SERVEUR UNIQUEMENT ────────────────
# OAuth Google Calendar. Ces 3 clés sont lues seulement par app/api/calendar/*,
# jamais NEXT_PUBLIC, jamais committées. GOOGLE_REDIRECT_URI doit pointer vers
# https://<domaine>/api/calendar/callback (et être déclaré dans la console Google).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Clé de chiffrement des jetons OAuth au repos (AES-256-GCM). 32 octets :
# hex (64 caractères) ou base64. Générer : openssl rand -hex 32
CALENDAR_TOKEN_KEY=

# ── Planning / géocodage + routage (Bloc C, à venir) — SERVEUR UNIQUEMENT ────
# Clé de l'API de géocodage + Distance Matrix (temps de trajet réel).
# GEOCODING_API_KEY=
# ROUTING_API_KEY=
